{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "OasgenProvider",
  "description": "Full-coverage values schema for the oasgen-provider chart, pinned to installer 2.7.0 / chart 0.9.0.",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "title": "Replica count"
    },
    "image": {
      "type": "object",
      "title": "Controller image",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "title": "Image repository"
        },
        "pullPolicy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "IfNotPresent",
            "Always",
            "Never"
          ]
        },
        "tag": {
          "type": "string",
          "title": "Image tag"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "title": "Image pull secrets",
      "items": {
        "type": "object"
      }
    },
    "nameOverride": {
      "type": "string",
      "title": "Name override"
    },
    "fullnameOverride": {
      "type": "string",
      "title": "Fullname override"
    },
    "serviceAccount": {
      "type": "object",
      "title": "Service account",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "title": "Create service account"
        },
        "automount": {
          "type": "boolean",
          "title": "Automount API credentials"
        },
        "annotations": {
          "type": "object",
          "title": "Service account annotations"
        },
        "name": {
          "type": "string",
          "title": "Service account name"
        }
      }
    },
    "podAnnotations": {
      "type": "object",
      "title": "Pod annotations"
    },
    "podLabels": {
      "type": "object",
      "title": "Pod labels"
    },
    "podSecurityContext": {
      "type": "object",
      "title": "Pod security context"
    },
    "securityContext": {
      "type": "object",
      "title": "Container security context"
    },
    "service": {
      "type": "object",
      "title": "Service",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "title": "Service type",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer",
          "title": "Service port"
        }
      }
    },
    "ingress": {
      "type": "object",
      "title": "Ingress",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Ingress enabled"
        },
        "className": {
          "type": "string",
          "title": "Ingress class name"
        },
        "annotations": {
          "type": "object",
          "title": "Ingress annotations"
        },
        "hosts": {
          "type": "array",
          "title": "Ingress hosts",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "title": "Ingress TLS",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "title": "Resources"
    },
    "autoscaling": {
      "type": "object",
      "title": "Autoscaling",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Autoscaling enabled"
        },
        "minReplicas": {
          "type": "integer",
          "title": "Minimum replicas"
        },
        "maxReplicas": {
          "type": "integer",
          "title": "Maximum replicas"
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "title": "Target CPU utilization percentage"
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "title": "Target memory utilization percentage"
        }
      }
    },
    "volumes": {
      "type": "array",
      "title": "Additional volumes",
      "items": {
        "type": "object"
      }
    },
    "volumeMounts": {
      "type": "array",
      "title": "Additional volume mounts",
      "items": {
        "type": "object"
      }
    },
    "nodeSelector": {
      "type": "object",
      "title": "Node selector"
    },
    "tolerations": {
      "type": "array",
      "title": "Tolerations",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "title": "Affinity"
    },
    "rdc": {
      "type": "object",
      "title": "rest-dynamic-controller (rdc)",
      "description": "Values for the rest-dynamic-controller sub-block deployed by oasgen-provider.",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "object",
          "title": "rdc image",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "type": "string",
              "title": "Image repository"
            },
            "pullPolicy": {
              "type": "string",
              "title": "Image pull policy",
              "enum": [
                "IfNotPresent",
                "Always",
                "Never"
              ]
            },
            "tag": {
              "type": "string",
              "title": "Image tag"
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "title": "Replica count"
        },
        "imagePullSecrets": {
          "type": "array",
          "title": "Image pull secrets",
          "items": {
            "type": "object"
          }
        },
        "nameOverride": {
          "type": "string",
          "title": "Name override"
        },
        "fullnameOverride": {
          "type": "string",
          "title": "Fullname override"
        },
        "serviceAccount": {
          "type": "object",
          "title": "Service account",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean",
              "title": "Create service account"
            },
            "automount": {
              "type": "boolean",
              "title": "Automount API credentials"
            },
            "annotations": {
              "type": "object",
              "title": "Service account annotations"
            },
            "name": {
              "type": "string",
              "title": "Service account name"
            }
          }
        },
        "podAnnotations": {
          "type": "object",
          "title": "Pod annotations"
        },
        "podLabels": {
          "type": "object",
          "title": "Pod labels"
        },
        "podSecurityContext": {
          "type": "object",
          "title": "Pod security context"
        },
        "securityContext": {
          "type": "object",
          "title": "Container security context"
        },
        "service": {
          "type": "object",
          "title": "Service",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "title": "Service type",
              "enum": [
                "ClusterIP",
                "NodePort",
                "LoadBalancer"
              ]
            },
            "port": {
              "type": "integer",
              "title": "Service port"
            }
          }
        },
        "ingress": {
          "type": "object",
          "title": "Ingress",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "Ingress enabled"
            },
            "className": {
              "type": "string",
              "title": "Ingress class name"
            },
            "annotations": {
              "type": "object",
              "title": "Ingress annotations"
            },
            "hosts": {
              "type": "array",
              "title": "Ingress hosts",
              "items": {
                "type": "object",
                "properties": {
                  "host": {
                    "type": "string"
                  },
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "pathType": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "tls": {
              "type": "array",
              "title": "Ingress TLS",
              "items": {
                "type": "object"
              }
            }
          }
        },
        "resources": {
          "type": "object",
          "title": "Resources"
        },
        "autoscaling": {
          "type": "object",
          "title": "Autoscaling",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "Autoscaling enabled"
            },
            "minReplicas": {
              "type": "integer",
              "title": "Minimum replicas"
            },
            "maxReplicas": {
              "type": "integer",
              "title": "Maximum replicas"
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "title": "Target CPU utilization percentage"
            },
            "targetMemoryUtilizationPercentage": {
              "type": "integer",
              "title": "Target memory utilization percentage"
            }
          }
        },
        "volumes": {
          "type": "array",
          "title": "Additional volumes",
          "items": {
            "type": "object"
          }
        },
        "volumeMounts": {
          "type": "array",
          "title": "Additional volume mounts",
          "items": {
            "type": "object"
          }
        },
        "nodeSelector": {
          "type": "object",
          "title": "Node selector"
        },
        "tolerations": {
          "type": "array",
          "title": "Tolerations",
          "items": {
            "type": "object"
          }
        },
        "affinity": {
          "type": "object",
          "title": "Affinity"
        },
        "env": {
          "type": "object",
          "title": "Environment variables",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "env": {
      "type": "object",
      "title": "Environment variables",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "OASGEN_PROVIDER_DEBUG": {
          "type": "string",
          "title": "Debug logging"
        },
        "OASGEN_PROVIDER_MAX_RECONCILE_RATE": {
          "type": [
            "integer",
            "string"
          ],
          "title": "Max reconcile rate"
        }
      }
    },
    "global": {
      "type": "object",
      "title": "Global values",
      "description": "Helm global values (injected when this chart is used as a subchart)."
    },
    "livenessProbe": {
      "type": "object",
      "description": "Kubernetes probe configuration (httpGet/tcpSocket/exec + timing). Empty/unset uses chart defaults.",
      "additionalProperties": true
    },
    "readinessProbe": {
      "type": "object",
      "description": "Kubernetes probe configuration (httpGet/tcpSocket/exec + timing). Empty/unset uses chart defaults.",
      "additionalProperties": true
    }
  }
}